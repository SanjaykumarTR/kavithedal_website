# ─────────────────────────────────────────────────────────────────────────────
# Kavithedal Publications — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

# Set to False in production, True only for local development
DEBUG=True

# Comma-separated list of allowed hostnames (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1


# ── Database ──────────────────────────────────────────────────────────────────
# Render provides this automatically for PostgreSQL databases.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# For local SQLite development, leave this unset.
DATABASE_URL=postgres://user:password@host:5432/kavithedal_db


# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_HOST_USER=your-gmail@gmail.com
# Use a Gmail App Password (not your account password):
# https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=Kavithedal Publications <your-gmail@gmail.com>


# ── PayU Payment Gateway ────────────────────────────────────────────────────────
# Get from https://merchant.payu.in → Settings → API Keys
# For sandbox: Use test credentials from https://sandbox.juspay.in
# Sandbox Key: pick from PayU sandbox dashboard
# Sandbox Salt: pick from PayU sandbox dashboard
PAYU_KEY=your-payu-merchant-key
PAYU_SALT=your-payu-merchant-salt
# Set to 'sandbox' for testing, 'production' for live
PAYU_ENV=sandbox
# PayU Base URL (optional — defaults based on PAYU_ENV)
# PAYU_BASE_URL=https://sandbox.juspay.in
# The full URL of your frontend (used in PayU return/failure redirects)
FRONTEND_URL=http://localhost:5173


# ── Admin Access ──────────────────────────────────────────────────────────────
# The ONLY email address permitted to log in to the admin panel (OTP-protected)
ADMIN_EMAIL=your-admin@gmail.com


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# ── Cloudinary (persistent media storage on Render) ──────────────────────────
# Required in production — Render's disk is ephemeral so uploads are lost on
# each redeploy without Cloudinary.
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
