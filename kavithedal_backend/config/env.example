# Environment Variables for Kavithedal Publications Backend
# Copy this file to .env and update with your values

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database Settings
DB_NAME=kavithedal_db
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# JWT Settings (optional - defaults are in settings.py)
# ACCESS_TOKEN_LIFETIME=60
# REFRESH_TOKEN_LIFETIME=10080
